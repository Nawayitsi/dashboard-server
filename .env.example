# ─── Database ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=homelabos_root
MYSQL_DATABASE=homelabos
MYSQL_USER=homelabos
MYSQL_PASSWORD=homelabos_password
DATABASE_URL=mysql://homelabos:homelabos_password@mysql:3306/homelabos

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
CORS_ORIGIN=http://localhost:3000

# ─── Integrations (configure as needed) ───────────────────
MIKROTIK_HOST=
MIKROTIK_PORT=8728
MIKROTIK_USERNAME=
MIKROTIK_PASSWORD=

NEXTCLOUD_URL=
NEXTCLOUD_USERNAME=
NEXTCLOUD_PASSWORD=

SYNOLOGY_URL=
SYNOLOGY_USERNAME=
SYNOLOGY_PASSWORD=

LIBRENMS_URL=
LIBRENMS_API_TOKEN=

SAFELINE_URL=
SAFELINE_API_TOKEN=

SIEM_URL=
SIEM_API_TOKEN=
